rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is an admin (owner or in admin/config.adminEmails)
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'agewaller@gmail.com' ||
        (
          exists(/databases/$(database)/documents/admin/config) &&
          request.auth.token.email in
            get(/databases/$(database)/documents/admin/config).data.adminEmails
        )
      );
    }

    // Per-user data: owner has full read/write; admin has read-only for management
    match /users/{userId} {
      // Owner can read and write everything in their doc.
      // Admin can read any user's doc for the user management tab.
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
      // Admins can list users for user management
      allow list: if isAdmin();

      match /{subcollection}/{docId} {
        // Owner has full access to their subcollections (records, history, etc.)
        // Admin can only read, not write.
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Admin shared config: all authenticated users can READ, only admin WRITE
    match /admin/config {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Admin secrets (API keys): readable by all authenticated users
    match /admin/secrets {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Other admin docs (prompts history, etc.)
    match /admin/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
