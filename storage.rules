rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Per-user file storage: only owner can read/write their files
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Admin shared files (readable by all authenticated users)
    match /admin/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'agewaller@gmail.com';
    }
  }
}
